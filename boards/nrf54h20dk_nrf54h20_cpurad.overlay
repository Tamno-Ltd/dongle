/*
 * Dongle ESB PRX cpurad overlay.
 *
 * Adds the devicetree nodes the ESB radio driver needs on nRF54H20 cpurad.
 * Mirrors the NCS esb_prx sample's cpurad overlay, minus the DK LED nodes
 * (this receiver has no LED code). The errata216 mboxes are the must-have:
 * both the NCS samples and the proven tempo radio app include them.
 */

/ {
	/* HMPAN-216 workaround: cpurad requests power-state changes from cpusys
	 * via VEVIF mboxes. Required by the ESB driver init on nRF54H20.
	 * Channels match the NCS esb_prx/esb_ptx samples and the tempo app.
	 */
	cpurad_cpusys_errata216_mboxes: errata216_mboxes {
		compatible = "zephyr,mbox-ipm";
		status = "okay";
		mboxes = <&cpusys_vevif 0x14>, <&cpusys_vevif 0x15>;
		mbox-names = "on_req", "off_req";
	};
};

/* Radio event routing used by the ESB driver on nRF54H20 (from the NCS
 * esb_prx sample's cpurad overlay).
 */
&gpiote130 {
	owned-channels = <0 1 2 3 4 5 6 7>;
	status = "okay";
};

&dppic020 {
	status = "okay";
	source-channels = <0 1 2 3 4 5>;
	sink-channels = <6 7 8 9 10 11>;
};
